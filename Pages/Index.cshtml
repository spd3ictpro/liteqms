@page
@model IndexModel
@{
    ViewData["Title"] = "Call Panel";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — LiteQMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: var(--index-bg);
            min-height: 100vh;
        }
        .setup-card {
            animation: slideUp 0.5s ease-out;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .brand-icon {
            width: 64px;
            height: 64px;
            margin-bottom: 1rem;
        }
        .brand-icon svg {
            width: 100%;
            height: 100%;
        }
        .input-icon-wrapper {
            position: relative;
        }
        .input-icon-wrapper .input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted, #64748b);
        }
        .input-icon-wrapper .form-control {
            padding-left: 3rem;
        }
        .footer-text {
            position: fixed;
            bottom: 1.5rem;
            left: 0;
            right: 0;
            text-align: center;
            color: var(--text-muted, #64748b);
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <div class="d-flex align-items-center justify-content-center min-vh-100">
        <div class="card shadow-lg setup-card" style="max-width: 440px; width: 100%;">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="brand-icon mx-auto">
                        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="4" y="4" width="56" height="56" rx="12" style="fill: var(--primary)"/>
                            <rect x="18" y="20" width="28" height="34" rx="2" fill="white" opacity="0.95"/>
                            <rect x="22" y="24" width="8" height="8" rx="1" fill="var(--primary)"/>
                            <rect x="34" y="24" width="8" height="8" rx="1" fill="var(--primary)"/>
                            <rect x="22" y="36" width="8" height="8" rx="1" fill="var(--primary)"/>
                            <rect x="34" y="36" width="8" height="8" rx="1" fill="var(--primary)"/>
                            <rect x="26" y="48" width="12" height="6" rx="1" fill="var(--primary)"/>
                            <rect x="24" y="14" width="16" height="10" rx="2" fill="white" opacity="0.9"/>
                        </svg>
                    </div>
                    <h1 class="h3 fw-bold" style="color: var(--primary-dark);">LiteQMS</h1>
                    <p class="text-muted">Enter your room number to begin</p>
                </div>
                <form method="post">
                    <div class="mb-4">
                        <label asp-for="RoomNumber" class="form-label fw-medium">Room Number</label>
                        <div class="input-icon-wrapper">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                <polyline points="9 22 9 12 15 12 15 22"/>
                            </svg>
                            <input asp-for="RoomNumber" type="text" class="form-control form-control-lg"
                                    placeholder="e.g., Bilik 1, Bilik 2, Bilik 3" autocomplete="off" autofocus />
                        </div>
                        <span asp-validation-for="RoomNumber" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">Proceed</button>
                </form>
            </div>
        </div>
    </div>
    <div class="footer-text">
        LiteQMS v1.0
        <span class="theme-dots ms-3">
            <button type="button" class="theme-dot teal theme-btn active" data-theme="teal" title="Teal theme"></button>
            <button type="button" class="theme-dot blue theme-btn" data-theme="blue" title="Medical Blue theme"></button>
            <button type="button" class="theme-dot dark theme-btn" data-theme="dark" title="Dark theme"></button>
        </span>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script>
        document.getElementById('RoomNumber').addEventListener('input', function() {
            this.value = this.value.toUpperCase();
        });
    </script>
</body>
</html>
