@page
@model IndexModel
@{
    ViewData["Title"] = "Call Panel";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — LiteQMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: var(--index-bg);
            min-height: 100vh;
        }
        .setup-card {
            animation: slideUp 0.5s ease-out;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .brand-icon {
            width: 64px;
            height: 64px;
            margin-bottom: 1rem;
        }
        .brand-icon svg {
            width: 100%;
            height: 100%;
        }
        .input-icon-wrapper {
            position: relative;
        }
        .input-icon-wrapper .input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted, #64748b);
        }
        .input-icon-wrapper .form-control {
            padding-left: 3rem;
        }
        .network-banner {
            margin-top: 1.5rem;
            padding: 0.6rem 1rem;
            background: var(--primary-bg, #f0fdfa);
            border: 1px solid var(--primary, #0d9488);
            border-radius: 0.5rem;
            text-align: center;
            font-size: 0.85rem;
            color: var(--primary-dark, #0f766e);
        }
        .footer-text {
            position: fixed;
            bottom: 1.5rem;
            left: 0;
            right: 0;
            text-align: center;
            color: var(--text-muted, #64748b);
            font-size: 0.875rem;
        }
        .arrow-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.4rem;
            max-width: 180px;
            margin: 0 auto;
        }
        .arrow-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            aspect-ratio: 1;
            border: 2px solid var(--border);
            border-radius: 0.5rem;
            background: var(--card-bg);
            cursor: pointer;
            transition: all 0.15s ease;
            padding: 0.4rem;
        }
        .arrow-btn svg {
            width: 22px;
            height: 22px;
            stroke: var(--text-muted);
            stroke-width: 2.5;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
            transition: stroke 0.15s ease;
        }
        .arrow-btn:hover {
            border-color: var(--primary-light);
            background: var(--primary-bg);
        }
        .arrow-btn:hover svg {
            stroke: var(--primary);
        }
        .arrow-btn.selected {
            border-color: var(--primary);
            background: var(--primary-bg);
        }
        .arrow-btn.selected svg {
            stroke: var(--primary);
        }
        .arrow-btn.none-btn {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--text-muted);
        }
        .arrow-btn.none-btn.selected {
            color: var(--primary);
        }
        .arrow-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            cursor: pointer;
            user-select: none;
            transition: color 0.15s ease;
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        .arrow-toggle:hover {
            color: var(--primary);
        }
        .arrow-toggle .chevron {
            transition: transform 0.2s ease;
        }
        .arrow-toggle .chevron.open {
            transform: rotate(180deg);
        }
        .arrow-collapse {
            overflow: hidden;
            transition: max-height 0.3s ease, opacity 0.25s ease;
            max-height: 0;
            opacity: 0;
        }
        .arrow-collapse.open {
            max-height: 250px;
            opacity: 1;
        }
    </style>
</head>
<body>
    <div class="d-flex align-items-center justify-content-center min-vh-100">
        <div class="card shadow-lg setup-card" style="max-width: 440px; width: 100%;">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="brand-icon mx-auto">
                        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="4" y="4" width="56" height="56" rx="12" style="fill: var(--primary)"/>
                            <rect x="18" y="20" width="28" height="34" rx="2" fill="white" opacity="0.95"/>
                            <rect x="22" y="24" width="8" height="8" rx="1" fill="var(--primary)"/>
                            <rect x="34" y="24" width="8" height="8" rx="1" fill="var(--primary)"/>
                            <rect x="22" y="36" width="8" height="8" rx="1" fill="var(--primary)"/>
                            <rect x="34" y="36" width="8" height="8" rx="1" fill="var(--primary)"/>
                            <rect x="26" y="48" width="12" height="6" rx="1" fill="var(--primary)"/>
                            <rect x="24" y="14" width="16" height="10" rx="2" fill="white" opacity="0.9"/>
                        </svg>
                    </div>
                    <h1 class="h3 fw-bold" style="color: var(--primary-dark);">LiteQMS</h1>
                    <p class="text-muted">Enter your room number to begin</p>
                </div>
                <form method="post">
                    <div class="mb-4">
                        <label asp-for="RoomNumber" class="form-label fw-medium">Room Number</label>
                        <div class="input-icon-wrapper">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                <polyline points="9 22 9 12 15 12 15 22"/>
                            </svg>
                            <input asp-for="RoomNumber" type="text" class="form-control form-control-lg"
                                    placeholder="e.g., Bilik 1, Bilik 2, Bilik 3" autocomplete="off" autofocus />
                        </div>
                        <span asp-validation-for="RoomNumber" class="text-danger"></span>
                    </div>
                    <div class="mb-4">
                        <div class="arrow-toggle" id="arrowToggle">
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9"/>
                            </svg>
                            Room Direction (optional)
                        </div>
                        <div class="arrow-collapse" id="arrowCollapse">
                            <div class="arrow-grid mt-2" id="arrowGrid">
                                <input type="hidden" asp-for="ArrowDirection" id="arrowHidden" />
                                <button type="button" class="arrow-btn" data-arrow="up-left"><svg viewBox="0 0 24 24"><line x1="20" y1="20" x2="4" y2="4"/><polyline points="10 4 4 4 4 10"/></svg></button>
                                <button type="button" class="arrow-btn" data-arrow="up"><svg viewBox="0 0 24 24"><line x1="12" y1="20" x2="12" y2="4"/><polyline points="6 10 12 4 18 10"/></svg></button>
                                <button type="button" class="arrow-btn" data-arrow="up-right"><svg viewBox="0 0 24 24"><line x1="4" y1="20" x2="20" y2="4"/><polyline points="14 4 20 4 20 10"/></svg></button>
                                <button type="button" class="arrow-btn" data-arrow="left"><svg viewBox="0 0 24 24"><line x1="20" y1="12" x2="4" y2="12"/><polyline points="10 18 4 12 10 6"/></svg></button>
                                <button type="button" class="arrow-btn none-btn selected" data-arrow="">✕</button>
                                <button type="button" class="arrow-btn" data-arrow="right"><svg viewBox="0 0 24 24"><line x1="4" y1="12" x2="20" y2="12"/><polyline points="14 18 20 12 14 6"/></svg></button>
                                <button type="button" class="arrow-btn" data-arrow="down-left"><svg viewBox="0 0 24 24"><line x1="20" y1="4" x2="4" y2="20"/><polyline points="10 20 4 20 4 14"/></svg></button>
                                <button type="button" class="arrow-btn" data-arrow="down"><svg viewBox="0 0 24 24"><line x1="12" y1="4" x2="12" y2="20"/><polyline points="6 14 12 20 18 14"/></svg></button>
                                <button type="button" class="arrow-btn" data-arrow="down-right"><svg viewBox="0 0 24 24"><line x1="4" y1="4" x2="20" y2="20"/><polyline points="14 20 20 20 20 14"/></svg></button>
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">Proceed</button>
                </form>
                <div class="network-banner">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.3rem; vertical-align: -2px;">
                        <circle cx="12" cy="12" r="10"/><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                    Other devices:
                    @foreach (var url in Model.LocalIPUrls)
                    {
                        <div><strong>@url</strong></div>
                    }
                </div>
                <div class="text-center mt-3">
                    <img src="data:image/png;base64,@Model.QrCodeBase64"
                         alt="QR Code for @Model.PrimaryIPUrl"
                         style="width: 160px; height: 160px; border-radius: 8px;" />
                    <p class="text-muted small mt-2 mb-0">Scan to open on your phone</p>
                </div>
            </div>
        </div>
    </div>
    <div class="footer-text">
                    LiteQMS v1.1.0
                    <a href="/Updates" class="text-muted text-decoration-none ms-3 small">Check for updates</a>
                    <span class="theme-dots ms-3">
            <button type="button" class="theme-dot teal theme-btn active" data-theme="teal" title="Teal theme"></button>
            <button type="button" class="theme-dot blue theme-btn" data-theme="blue" title="Medical Blue theme"></button>
            <button type="button" class="theme-dot dark theme-btn" data-theme="dark" title="Dark theme"></button>
        </span>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script>
        document.getElementById('RoomNumber').addEventListener('input', function() {
            this.value = this.value.toUpperCase();
        });

        (function() {
            var grid = document.getElementById('arrowGrid');
            var hidden = document.getElementById('arrowHidden');
            if (!grid || !hidden) return;

            grid.addEventListener('click', function(e) {
                var btn = e.target.closest('.arrow-btn');
                if (!btn) return;

                grid.querySelectorAll('.arrow-btn').forEach(function(b) {
                    b.classList.remove('selected');
                });
                btn.classList.add('selected');
                hidden.value = btn.dataset.arrow || '';
            });

            var toggle = document.getElementById('arrowToggle');
            var collapse = document.getElementById('arrowCollapse');
            if (toggle && collapse) {
                toggle.addEventListener('click', function() {
                    collapse.classList.toggle('open');
                    toggle.querySelector('.chevron').classList.toggle('open');
                });
            }
        })();
    </script>
</body>
</html>
