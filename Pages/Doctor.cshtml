@page
@model DoctorModel
@{
    ViewData["Title"] = "Call Patient";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — @Model.RoomNumber — LiteQMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .navbar {
            background: linear-gradient(135deg, #0d9488, #0f766e) !important;
        }
        .room-badge {
            background: rgba(255, 255, 255, 0.2);
            padding: 0.35rem 1rem;
            border-radius: 2rem;
            font-weight: 600;
            font-size: 0.875rem;
        }
        .preview-card {
            background: #042f2e;
            border: 2px solid rgba(20, 184, 166, 0.3);
            border-radius: 0.75rem;
            overflow: hidden;
        }
        .preview-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 1rem;
            background: rgba(255, 255, 255, 0.05);
            border-bottom: 1px solid rgba(20, 184, 166, 0.2);
        }
        .preview-label {
            color: #14b8a6;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        .live-dot {
            width: 8px;
            height: 8px;
            background: #14b8a6;
            border-radius: 50%;
            animation: livePulse 2s ease-in-out infinite;
        }
        @@keyframes livePulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }
        .preview-body {
            padding: 2rem 1rem;
            text-align: center;
        }
        .preview-room {
            color: rgba(255, 255, 255, 0.5);
            font-size: 1rem;
            margin-bottom: 0.5rem;
        }
        .preview-number {
            color: #fff;
            font-size: 4rem;
            font-weight: 800;
            line-height: 1;
            text-shadow: 0 0 30px rgba(20, 184, 166, 0.4);
            transition: all 0.3s ease;
        }
        .preview-number.pulse {
            animation: previewPulse 0.5s ease-out;
        }
        @@keyframes previewPulse {
            0% { transform: scale(0.9); opacity: 0.5; }
            100% { transform: scale(1); opacity: 1; }
        }
        .call-count-badge {
            background: #f0fdfa;
            color: #0d9488;
            padding: 0.25rem 0.75rem;
            border-radius: 1rem;
            font-size: 0.8rem;
            font-weight: 600;
        }
        .hint-text {
            color: #64748b;
            font-size: 0.8rem;
            margin-top: 0.5rem;
        }
        .hint-text kbd {
            background: #e2e8f0;
            padding: 0.15rem 0.4rem;
            border-radius: 0.25rem;
            font-size: 0.75rem;
        }
        .input-wrapper {
            position: relative;
        }
        .input-wrapper .input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #64748b;
        }
        .input-wrapper .form-control {
            padding-left: 3rem;
        }
        .validation-icon {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            display: none;
        }
        .validation-icon.valid { color: #059669; display: block; }
        .validation-icon.invalid { color: #dc2626; display: block; }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark">
        <div class="container-fluid">
            <div class="d-flex align-items-center gap-3">
                <span class="navbar-brand mb-0 h1 fw-bold">LiteQMS</span>
                <span class="room-badge">@Model.RoomNumber</span>
            </div>
            <div>
                <a href="/History" class="btn btn-outline-light btn-sm">History</a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-3 fw-semibold">Call Patient</h5>
                        <form method="post" id="callForm">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                            @if (Model.IsDuplicate)
                            {
                                <div class="alert alert-warning d-flex align-items-center" role="alert">
                                    <svg class="bi flex-shrink-0 me-2" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M8 16A6 6 0 1 1 8 4a6 6 0 0 1 0 12zm.5-5a.5.5 0 0 0-1 0v3a.5.5 0 0 0 1 0v-3zm0-4a.5.5 0 0 0-1 0 .5.5 0 0 0 1 0z"/>
                                    </svg>
                                    <div>This patient number was already called today.</div>
                                </div>
                            }

                            <div class="mb-3">
                                <label asp-for="PatientNumber" class="form-label fw-medium">Patient Number</label>
                                <div class="input-wrapper">
                                    <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                        <circle cx="12" cy="7" r="4"/>
                                    </svg>
                                    <input asp-for="PatientNumber" type="text" class="form-control form-control-lg"
                                           placeholder="Enter patient number, e.g., 1234" id="patientInput" autofocus />
                                    <span class="validation-icon" id="validIcon">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    </span>
                                    <span class="validation-icon" id="invalidIcon">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </span>
                                </div>
                                <div class="hint-text">Format: 1xxx, 3xxx, 5xxx, 7xxx (4 digits starting with 1, 3, 5, or 7)</div>
                                <span asp-validation-for="PatientNumber" class="text-danger"></span>
                            </div>
                            <button type="submit" class="btn btn-success btn-lg w-100" id="callBtn">
                                Call Patient
                            </button>
                        </form>
                    </div>
                </div>

                <div class="card shadow-sm mt-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="card-title mb-0 fw-semibold">Recent Calls</h5>
                            @if (Model.RecentCalls.Count > 0)
                            {
                                <span class="call-count-badge">@Model.RecentCalls.Count today</span>
                            }
                        </div>
                        @if (Model.RecentCalls.Count == 0)
                        {
                            <p class="text-muted mb-0">No calls yet today.</p>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var call in Model.RecentCalls)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center @(call.IsCNA ? "opacity-50" : "")">
                                        <div class="d-flex align-items-center gap-2">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="@(call.IsCNA ? "text-muted" : "text-success")">
                                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                            </svg>
                                            <div>
                                                <strong>@call.PatientNumber</strong>
                                                <small class="text-muted ms-2">@call.Timestamp.ToString("HH:mm")</small>
                                                @if (call.IsCNA)
                                                {
                                                    <span class="badge bg-danger ms-2">CNA</span>
                                                }
                                            </div>
                                        </div>
                                        <form method="post" asp-page-handler="CNA" class="d-inline">
                                            <input type="hidden" name="id" value="@call.Id" />
                                            <button type="submit" class="btn btn-sm @(call.IsCNA ? "btn-outline-secondary" : "btn-outline-danger")">
                                                @(call.IsCNA ? "Undo CNA" : "CNA")
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="preview-card shadow-sm" id="previewCard">
                    <div class="preview-header">
                        <span class="preview-label">Display Preview</span>
                        <div class="d-flex align-items-center gap-2">
                            <div class="live-dot"></div>
                            <small class="text-white-50">Live</small>
                        </div>
                    </div>
                    <div class="preview-body" id="previewDisplay">
                        <div class="preview-room" id="previewRoom">@Model.RoomNumber</div>
                        <div class="preview-number" id="previewNumber">—</div>
                    </div>
                </div>

                <div class="hint-text mt-3">
                    Press <kbd>Enter</kbd> to call patient &middot; CNA marks "Called Not Answered"
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8/dist/browser/signalr.min.js"></script>
    <script src="~/js/doctor-client.js" asp-append-version="true"></script>
</body>
</html>
