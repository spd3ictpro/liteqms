@page
@model HistoryModel
@{
    ViewData["Title"] = "Call History";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — LiteQMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .navbar {
            background: linear-gradient(135deg, var(--navbar-bg), var(--navbar-bg-end)) !important;
        }
        .table thead th {
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 2px solid var(--primary-dark);
        }
        .table tbody tr {
            transition: background-color 0.2s ease;
        }
        .table tbody tr:hover {
            background-color: var(--primary-bg);
        }
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
        }
        .empty-state svg {
            color: var(--text-muted);
            margin-bottom: 1rem;
        }
        .clear-filter {
            display: none;
        }
        .clear-filter.visible {
            display: inline-block;
        }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1 fw-bold">LiteQMS — Call History</span>
            <div class="d-flex align-items-center gap-2">
                <div class="dropdown theme-dropdown">
                    <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Change theme">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><button class="dropdown-item theme-btn active" data-theme="teal"><span class="theme-indicator teal"></span>Teal</button></li>
                        <li><button class="dropdown-item theme-btn" data-theme="blue"><span class="theme-indicator blue"></span>Medical Blue</button></li>
                        <li><button class="dropdown-item theme-btn" data-theme="dark"><span class="theme-indicator dark"></span>Dark</button></li>
                    </ul>
                </div>
                <a href="/Doctor" class="btn btn-outline-light me-2">Doctor</a>
                <a href="/Display" class="btn btn-outline-light" target="_blank">Display</a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-auto">
                        <label for="dateFrom" class="form-label fw-medium">From</label>
                        <input type="date" id="dateFrom" name="DateFrom" value="@Model.DateFrom" class="form-control" />
                    </div>
                    <div class="col-auto">
                        <label for="dateTo" class="form-label fw-medium">To</label>
                        <input type="date" id="dateTo" name="DateTo" value="@Model.DateTo" class="form-control" />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">Filter</button>
                    </div>
                    <div class="col-auto">
                        <a href="/History" class="btn btn-outline-secondary clear-filter @(Model.DateFrom != DateTime.Today.ToString("yyyy-MM-dd") || Model.DateTo != DateTime.Today.ToString("yyyy-MM-dd") ? "visible" : "")">Clear</a>
                    </div>
                    <div class="col-auto">
                        <span class="text-muted small">@Model.Records.Count records</span>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Room</th>
                                <th>Patient Number</th>
                                <th>Timestamp</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Records.Count == 0)
                            {
                                <tr>
                                    <td colspan="4">
                                        <div class="empty-state">
                                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="12" cy="12" r="10"/>
                                                <line x1="12" y1="8" x2="12" y2="12"/>
                                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                                            </svg>
                                            <p class="text-muted mb-0">No records found for the selected date range.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var record in Model.Records)
                                {
                                    <tr class="@(record.IsCNA ? "table-danger" : "")">
                                        <td>@record.RoomNumber</td>
                                        <td><strong>@record.PatientNumber</strong></td>
                                        <td>@record.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                        <td>
                                            @if (record.IsCNA)
                                            {
                                                <span class="badge bg-danger">CNA</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Answered</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
</body>
</html>
