@page
@model CallPanelModel
@{
    ViewData["Title"] = "Call Patient";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — @Model.RoomNumber — LiteQMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .navbar {
            background: linear-gradient(135deg, var(--navbar-bg), var(--navbar-bg-end)) !important;
        }
        .room-badge {
            background: rgba(255, 255, 255, 0.2);
            padding: 0.35rem 1rem;
            border-radius: 2rem;
            font-weight: 600;
            font-size: 0.875rem;
        }
        .preview-card {
            background: var(--preview-bg);
            border: 2px solid rgba(var(--primary-light-rgb), 0.3);
            border-radius: 0.75rem;
            overflow: hidden;
        }
        .preview-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 1rem;
            background: rgba(255, 255, 255, 0.05);
            border-bottom: 1px solid rgba(var(--primary-light-rgb), 0.2);
        }
        .preview-label {
            color: var(--primary-light);
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        .live-dot {
            width: 8px;
            height: 8px;
            background: var(--primary-light);
            border-radius: 50%;
            animation: livePulse 2s ease-in-out infinite;
        }
        @@keyframes livePulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }
        .preview-body {
            padding: 2rem 1rem;
            text-align: center;
        }
        .preview-room {
            color: rgba(255, 255, 255, 0.5);
            font-size: 1rem;
            margin-bottom: 0.5rem;
        }
        .preview-number {
            color: var(--text-on-dark);
            font-size: 4rem;
            font-weight: 800;
            line-height: 1;
            text-shadow: 0 0 30px rgba(var(--primary-light-rgb), 0.4);
            transition: all 0.3s ease;
        }
        .preview-number.pulse {
            animation: previewPulse 0.5s ease-out;
        }
        @@keyframes previewPulse {
            0% { transform: scale(0.9); opacity: 0.5; }
            100% { transform: scale(1); opacity: 1; }
        }
        .recent-section {
            border-top: 1px solid rgba(var(--primary-light-rgb), 0.2);
            padding: 1rem;
        }
        .recent-title {
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 0.75rem;
        }
        .recent-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
            margin-bottom: 0.35rem;
            background: rgba(255, 255, 255, 0.03);
            transition: background 0.2s ease;
        }
        .recent-item:hover {
            background: rgba(255, 255, 255, 0.06);
        }
        .recent-item.cna {
            opacity: 0.4;
        }
        .recent-item-info {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .recent-item-number {
            color: var(--text-on-dark);
            font-weight: 700;
            font-size: 1.1rem;
        }
        .recent-item-room {
            color: rgba(255, 255, 255, 0.4);
            font-size: 0.8rem;
        }
        .recent-item-time {
            color: rgba(255, 255, 255, 0.3);
            font-size: 0.75rem;
            margin-left: 0.25rem;
        }
        .recent-item .btn {
            padding: 0.15rem 0.5rem;
            font-size: 0.7rem;
        }
        .cna-btn {
            background: transparent;
            border: none;
            padding: 0.3rem 0.75rem;
            border-radius: 0.35rem;
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.15s ease;
        }
        .cna-btn.mark {
            color: #f87171;
        }
        .cna-btn.mark:hover {
            background: rgba(248, 113, 113, 0.15);
        }
        .cna-btn.undo {
            color: var(--text-muted);
        }
        .cna-btn.undo:hover {
            background: rgba(255, 255, 255, 0.08);
        }
        .recent-empty {
            color: rgba(255, 255, 255, 0.3);
            font-size: 0.85rem;
            text-align: center;
            padding: 1rem 0;
        }
        .hint-text {
            color: var(--text-muted);
            font-size: 0.8rem;
            margin-top: 0.5rem;
        }
        .hint-text kbd {
            background: var(--border);
            padding: 0.15rem 0.4rem;
            border-radius: 0.25rem;
            font-size: 0.75rem;
        }
        .call-patient-card .card-body {
            display: flex;
            flex-direction: column;
        }
        .digit-inputs {
            display: flex;
            gap: 1rem;
            justify-content: center;
        }
        .digit-input {
            width: 3.5rem;
            height: 4rem;
            text-align: center;
            font-size: 2rem;
            font-weight: 700;
            border: 2px solid var(--border);
            border-radius: 0.75rem;
            transition: all 0.2s ease;
            caret-color: transparent;
        }
        .digit-input:focus {
            border-color: var(--primary-light);
            box-shadow: 0 0 0 0.2rem var(--focus-ring);
            outline: none;
        }
        .digit-input.is-valid {
            border-color: var(--success);
        }
        .digit-input.is-invalid {
            border-color: var(--danger);
        }
        .digit-group-label {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
        }
        .sync-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 0.35rem;
            transition: background 0.3s ease;
        }
        .sync-dot.connected {
            background: #22c55e;
            box-shadow: 0 0 6px rgba(34, 197, 94, 0.5);
        }
        .sync-dot.disconnected {
            background: #ef4444;
            box-shadow: 0 0 6px rgba(239, 68, 68, 0.5);
        }
        .recall-btn {
            background: transparent;
            border: none;
            padding: 0.3rem 0.75rem;
            border-radius: 0.35rem;
            font-size: 0.7rem;
            font-weight: 600;
            cursor: pointer;
            color: var(--primary-light);
            transition: background 0.15s ease;
        }
        .recall-btn:hover {
            background: rgba(var(--primary-light-rgb), 0.15);
        }
        .preview-recall-btn {
            margin-top: 1rem;
            padding: 0.5rem 1.5rem;
            font-size: 0.85rem;
            border: 1px solid rgba(var(--primary-light-rgb), 0.4);
            border-radius: 0.5rem;
        }
        .preview-recall-btn:hover {
            background: rgba(var(--primary-light-rgb), 0.2);
        }
        .call-count-badge {
            margin-top: 0.75rem;
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.85rem;
        }
        .call-count-badge strong {
            color: var(--primary-light);
            font-weight: 700;
        }
        .recall-feedback-success {
            color: var(--success);
        }
        .recall-feedback-warning {
            color: var(--warning);
        }
        .recall-feedback-error {
            color: var(--danger);
        }

        .mobile-numpad { display: none; }

        @@media (max-width: 768px) {
            .navbar { padding-top: 0.5rem !important; padding-bottom: 0.5rem !important; }
            .navbar .navbar-brand { font-size: 1.4rem; }
            .navbar .room-badge { font-size: 0.8rem; padding: 0.3rem 0.75rem; }
            .navbar .btn-outline-light { padding: 0.3rem 0.5rem; font-size: 0.8rem; }
            .room-badge .sync-dot,
            .room-badge #syncLabel { display: none; }
            .container { padding-top: 0.5rem !important; padding-bottom: 0.5rem !important; }
            .call-patient-card .card-body { padding: 1rem !important; }
            .form-label.fw-medium.mb-5 { margin-bottom: 0.75rem !important; }
            .mb-5 { margin-bottom: 1rem !important; }
            .row.g-4 { gap: 0.5rem !important; }
            .hint-text { display: none; }
            .digit-inputs { gap: 0.5rem; }
            .digit-input { width: 4rem; height: 4.5rem; font-size: 2.2rem; }
            .mobile-numpad { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin-top: 0.75rem; }
            .numpad-btn { height: 3.5rem; font-size: 1.5rem; font-weight: 700; border: 1px solid var(--border); border-radius: 0.75rem; background: var(--card-bg); color: var(--text-dark); cursor: pointer; -webkit-tap-highlight-color: transparent; user-select: none; }
            .numpad-btn:active { background: var(--primary-bg); }
            .numpad-btn.clear { color: var(--danger); }
            .numpad-btn svg { vertical-align: middle; }
            .btn-lg { font-size: 1.1rem; padding: 0.75rem 1rem; }
            .preview-number { font-size: 2.5rem; }
            .preview-header { padding: 0.5rem 0.75rem; }
            .preview-body { padding: 1rem 0.75rem; }
            .recent-item .recall-btn,
            .recent-item .cna-btn { padding: 0.4rem 0.75rem; font-size: 0.85rem; }
            .preview-recall-btn { padding: 0.4rem 1rem; font-size: 0.8rem; }
        }
    </style>
</head>
<body class="bg-light" data-room="@Model.RoomNumber">
    <nav class="navbar navbar-dark">
        <div class="container-fluid">
            <div class="d-flex align-items-center gap-3">
                <span class="navbar-brand mb-0 h1 fw-bold">LiteQMS</span>
                <span class="room-badge">@Model.RoomNumber</span>
                <span class="room-badge d-flex align-items-center">
                    <span class="sync-dot connected" id="syncDot"></span>
                    <span id="syncLabel">Connected</span>
                </span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="dropdown theme-dropdown">
                    <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Change theme">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><button class="dropdown-item theme-btn active" data-theme="teal"><span class="theme-indicator teal"></span>Teal</button></li>
                        <li><button class="dropdown-item theme-btn" data-theme="blue"><span class="theme-indicator blue"></span>Medical Blue</button></li>
                        <li><button class="dropdown-item theme-btn" data-theme="dark"><span class="theme-indicator dark"></span>Dark</button></li>
                    </ul>
                </div>
                <a href="/History" class="btn btn-outline-light">History</a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card shadow-sm call-patient-card h-100">
                    <div class="card-body py-4">
                        <h5 class="card-title mb-4 fw-semibold">Call Patient</h5>
                        <form method="post" id="callForm">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                            <div class="mb-5">
                                <label asp-for="PatientNumber" class="form-label fw-medium mb-5">Patient Number</label>
                                <input type="hidden" asp-for="PatientNumber" id="patientNumberHidden" />
                                <div class="digit-inputs">
                                    <input type="text" inputmode="numeric" pattern="[0-9]" maxlength="1"
                                           class="digit-input" id="digit1" data-index="0" autocomplete="off" autofocus />
                                    <input type="text" inputmode="numeric" pattern="[0-9]" maxlength="1"
                                           class="digit-input" id="digit2" data-index="1" autocomplete="off" />
                                    <input type="text" inputmode="numeric" pattern="[0-9]" maxlength="1"
                                           class="digit-input" id="digit3" data-index="2" autocomplete="off" />
                                    <input type="text" inputmode="numeric" pattern="[0-9]" maxlength="1"
                                           class="digit-input" id="digit4" data-index="3" autocomplete="off" />
                                </div>
                                <div class="text-center mt-2">
                                    <span id="validIcon" style="display: none; color: var(--success);">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    </span>
                                    <span id="invalidIcon" style="display: none; color: var(--danger);">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </span>
                                </div>
                                <span asp-validation-for="PatientNumber" class="text-danger"></span>
                                <div id="recallFeedback" class="text-center mt-2" style="display: none;">
                                    <span id="recallFeedbackText" class="fw-medium" style="font-size: 0.85rem;"></span>
                                </div>
                            </div>
                            <div class="mobile-numpad" id="mobileNumpad">
                                <button type="button" class="numpad-btn" data-digit="1">1</button>
                                <button type="button" class="numpad-btn" data-digit="2">2</button>
                                <button type="button" class="numpad-btn" data-digit="3">3</button>
                                <button type="button" class="numpad-btn" data-digit="4">4</button>
                                <button type="button" class="numpad-btn" data-digit="5">5</button>
                                <button type="button" class="numpad-btn" data-digit="6">6</button>
                                <button type="button" class="numpad-btn" data-digit="7">7</button>
                                <button type="button" class="numpad-btn" data-digit="8">8</button>
                                <button type="button" class="numpad-btn" data-digit="9">9</button>
                                <button type="button" class="numpad-btn" data-action="backspace">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 4H8l-7 8 7 8h13a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z"/><line x1="18" y1="9" x2="12" y2="15"/><line x1="12" y1="9" x2="18" y2="15"/></svg>
                                </button>
                                <button type="button" class="numpad-btn" data-digit="0">0</button>
                                <button type="button" class="numpad-btn clear" data-action="clear">Clear</button>
                            </div>
                            <div class="d-flex gap-3">
                                <button type="button" class="btn btn-outline-secondary btn-lg" id="clearBtn">
                                    Clear
                                </button>
                                <button type="submit" class="btn btn-primary btn-lg flex-grow-1" id="callBtn">
                                    Call Patient
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="hint-text mt-3">
                    Press <kbd>Enter</kbd> to call patient &middot; CNA marks "Called Not Answered"
                </div>
            </div>

            <div class="col-lg-7">
                <div class="preview-card shadow-sm h-100" id="previewCard">
                    <div class="preview-header">
                        <span class="preview-label">Display Preview</span>
                        <div class="d-flex align-items-center gap-2">
                            <div class="live-dot"></div>
                            <small class="text-white-50">Live</small>
                        </div>
                    </div>
                    <div class="preview-body" id="previewDisplay">
                        <div class="preview-room" id="previewRoom">@(Model.PreviewRoomNumber ?? Model.RoomNumber)</div>
                        <div class="preview-number" id="previewNumber">@(Model.PreviewPatientNumber ?? "—")</div>
                        <div id="callCountBadge" class="call-count-badge" style="@(Model.PreviewPatientNumber != null && Model.CallCount > 0 ? "" : "display: none;")">
                            Called <strong id="callCountValue">@(Model.CallCount > 0 ? Model.CallCount + 1 : 0)</strong> times today
                        </div>
                        <button type="button" class="recall-btn preview-recall-btn" id="previewRecallBtn"
                                data-patient="@(Model.PreviewPatientNumber ?? "")"
                                style="@(string.IsNullOrEmpty(Model.PreviewPatientNumber) ? "display: none;" : "")">
                            Recall
                        </button>
                    </div>
                    <div class="recent-section">
                        <div class="recent-title">Recently Called</div>
                        <div id="previewRecentCalls">
                            @if (Model.PreviewRecentCalls.Count == 0)
                            {
                                <div class="recent-empty">No recent calls</div>
                            }
                            else
                            {
                                @foreach (var call in Model.PreviewRecentCalls)
                                {
                                    <div class="recent-item @(call.IsCNA ? "cna" : "")" id="recent-@call.Id">
                                        <div class="recent-item-info">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="@(call.IsCNA ? "text-muted" : "text-success")">
                                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                            </svg>
                                            <span class="recent-item-number">@call.PatientNumber</span>
                                            <span class="recent-item-room">@call.RoomNumber</span>
                                            <span class="recent-item-time">@call.Timestamp.ToString("HH:mm")</span>
                                            @if (call.IsCNA)
                                            {
                                                <span class="badge bg-danger ms-1" style="font-size: 0.65rem;">CNA</span>
                                            }
                                        </div>
                                        <div class="d-flex gap-1">
                                            <button type="button" class="recall-btn" data-patient="@call.PatientNumber">Recall</button>
                                            <button type="button" class="cna-btn @(call.IsCNA ? "undo" : "mark")"
                                                    data-cna-id="@call.Id" data-cna-active="@call.IsCNA.ToString().ToLower()">
                                                @(call.IsCNA ? "Undo" : "CNA")
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script src="~/js/call-panel-client.js" asp-append-version="true"></script>
    <script>
        (function() {
            var inputs = [
                document.getElementById('digit1'),
                document.getElementById('digit2'),
                document.getElementById('digit3'),
                document.getElementById('digit4')
            ];
            var numpad = document.getElementById('mobileNumpad');
            if (!numpad) return;

            var mq = window.matchMedia('(max-width: 768px) and (pointer: coarse)');
            function toggleReadOnly(e) {
                inputs.forEach(function(i) { i.readOnly = e.matches; });
            }
            mq.addEventListener('change', toggleReadOnly);
            toggleReadOnly(mq);

            numpad.addEventListener('click', function(e) {
                var btn = e.target.closest('.numpad-btn');
                if (!btn) return;

                if (btn.dataset.action === 'clear') {
                    inputs.forEach(function(i) { i.value = ''; });
                    inputs[0].focus();
                    if (inputs[0]) {
                        var ev = new Event('input', { bubbles: true });
                        inputs[0].dispatchEvent(ev);
                    }
                    return;
                }

                if (btn.dataset.action === 'backspace') {
                    for (var i = 3; i >= 0; i--) {
                        if (inputs[i].value) {
                            inputs[i].value = '';
                            inputs[i].focus();
                            var ev = new Event('input', { bubbles: true });
                            inputs[i].dispatchEvent(ev);
                            break;
                        }
                    }
                    return;
                }

                var digit = btn.dataset.digit;
                if (digit !== undefined) {
                    for (var i = 0; i < 4; i++) {
                        if (!inputs[i].value) {
                            inputs[i].value = digit;
                            var ev = new Event('input', { bubbles: true });
                            inputs[i].dispatchEvent(ev);
                            break;
                        }
                    }
                }
            });
        })();
    </script>
</body>
</html>
